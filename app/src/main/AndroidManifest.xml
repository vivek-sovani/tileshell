<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        TileShell enumerates launchable apps. Per CLAUDE.md we deliberately
        avoid QUERY_ALL_PACKAGES and instead declare visibility into the set
        of activities that handle the LAUNCHER category.
    -->
    <!--
        Opt-in live-tile data (FR-2.x). Both are dangerous permissions requested
        at runtime by the weather / calendar tiles; when denied those tiles
        degrade to a static glyph. Coarse (not fine) location is enough for a
        city-level forecast.
    -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- People tile (FR-2): contact names + thumbnails for the avatar mosaic. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Weather tile (FR-2): fetch a live, location-specific forecast from the
         no-API-key Open-Meteo service. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- App-list "uninstall" context-menu action: lets the launcher ask the system
         to uninstall a user app (the user still confirms in the platform dialog). -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <!-- Battery-exemption request (S28): opens the system dialog that adds
         TileShell to the Doze whitelist so the notification listener service
         keeps running on OEM devices with aggressive battery killers. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Quick panel (two-finger swipe-up on Start) + glance device-status card:
         both normal-protection permissions, auto-granted at install with no
         runtime prompt and no Play Console Data Safety disclosure — reading
         Wi-Fi on/off state and the active network's transport type. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Quick panel: rotation lock / brightness / screen timeout. WRITE_SETTINGS is
         a special app-op (granted via a one-time Settings deep link, same shape as
         the notification-listener/DND flows), not a manifest "dangerous" permission
         — confirmed absent from Play Console's restricted-permissions list, so it
         needs no Permissions Declaration Form / extended review. -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <!-- Make the system uninstaller resolvable under package visibility so the
             app-list "uninstall" action can launch it. -->
        <intent>
            <action android:name="android.intent.action.DELETE" />
            <data android:scheme="package" />
        </intent>
        <!-- Standard app-role selectors (Intent.CATEGORY_APP_*). Visibility for
             these lets the category-folder classifier ask the platform which apps
             are an email / messaging / maps / music / … app, refining the coarse
             ApplicationInfo.category without any hard-coded package list. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_EMAIL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MESSAGING" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CONTACTS" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MUSIC" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_GALLERY" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MAPS" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_BROWSER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALCULATOR" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALENDAR" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MARKET" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_FILES" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_WEATHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_FITNESS" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TileShell">

        <!-- Lets the Macrobenchmark/baseline-profile tooling capture profileable
             traces from non-debuggable (release/benchmark) builds (S26). -->
        <profileable android:shell="true" />

        <!-- Accessibility service used to lock the screen via GLOBAL_ACTION_LOCK_SCREEN
             (API 28+). Preserves biometric unlock unlike DevicePolicyManager.lockNow(). -->
        <service
            android:name=".LockAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/lock_accessibility_service" />
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
        </service>

        <!-- Device-admin receiver that grants the force-lock policy, used by
             the double-tap-to-sleep gesture on the Start screen. The user
             must activate it once via the system's device-admin prompt. -->
        <receiver
            android:name=".LockAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.TileShell">

            <!-- HOME/DEFAULT makes the device offer TileShell as a Home choice;
                 LAUNCHER keeps it openable from another launcher before that. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
