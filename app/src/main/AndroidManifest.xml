<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        TileShell enumerates launchable apps. Per CLAUDE.md we deliberately
        avoid QUERY_ALL_PACKAGES and instead declare visibility into the set
        of activities that handle the LAUNCHER category.
    -->
    <!--
        Opt-in live-tile data (FR-2.x). Both are dangerous permissions requested
        at runtime by the weather / calendar tiles; when denied those tiles
        degrade to a static glyph. Coarse (not fine) location is enough for a
        city-level forecast.
    -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- People tile (FR-2): contact names + thumbnails for the avatar mosaic. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TileShell">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:theme="@style/Theme.TileShell">

            <!-- HOME/DEFAULT makes the device offer TileShell as a Home choice;
                 LAUNCHER keeps it openable from another launcher before that. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
